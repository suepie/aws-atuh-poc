# Cognito設定（terraform output から取得）
VITE_COGNITO_AUTHORITY=https://cognito-idp.ap-northeast-1.amazonaws.com/ap-northeast-1_XXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=https://auth-poc-central.auth.ap-northeast-1.amazoncognito.com
VITE_REDIRECT_URI=http://localhost:5173/callback
VITE_POST_LOGOUT_URI=http://localhost:5173/

# Phase 2: 外部IdP名（Auth0連携時に設定、空ならフェデレーションボタン非表示）
VITE_AUTH0_IDP_NAME=Auth0

# Phase 2: Auth0 完全ログアウト用（Auth0セッションも破棄する場合に必要）
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phase 3: API Gateway エンドポイント（terraform output から取得）
VITE_API_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/prod
