        <!-- CloudFront-AppC セット (例) -->
        <mxCell id="appc_box" value="セット 5+: CloudFront-AppC.. (公開 API、取引先連携) - N アプリ分独立" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;fontStyle=1;align=left;verticalAlign=top;dashed=5;" vertex="1" parent="1">
          <mxGeometry x="1300" y="280" width="940" height="380" as="geometry" />
        </mxCell>
