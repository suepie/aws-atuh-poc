        <!-- ===== ネットワーク監査 Acct 全体枠 ===== -->
        <mxCell id="netaudit_container" value="🟣 ネットワーク監査 Acct (Network 監査チーム) — Shield Advanced で全 CloudFront 保護 + Network Firewall で Egress / East-West 検査" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=13;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
