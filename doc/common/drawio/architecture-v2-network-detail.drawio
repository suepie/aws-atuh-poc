        </mxCell>
        <mxCell id="waf_appc_d" value="WAF-AppC&#xa;Common&#xa;+ 取引先&#xa;IP Allowlist&#xa;+ API Token 検証" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#232F3E;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.waf;" vertex="1" parent="1">
