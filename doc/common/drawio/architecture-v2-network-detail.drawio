        </mxCell>
        <mxCell id="es8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;endArrow=classic;" edge="1" parent="1" source="waf_appb_d" target="le_appb_d">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

