        <!-- ===== タイトル ===== -->
        <mxCell id="title" value="ネットワーク監査 Acct 詳細&#xa;アプリごと独立 CloudFront + WAF + Lambda@Edge セット (1 アプリ = 1 セット)&#xa;(2026-06-25 / ADR-039 v2 §A §B)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
