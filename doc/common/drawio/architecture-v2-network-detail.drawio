        </mxCell>
        <mxCell id="cf_more" value="...&#xa;(N アプリ分&#xa;CloudFront / WAF / Lambda@Edge セット&#xa;独立配置)" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fillColor=none;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="1700" y="450" width="380" height="120" as="geometry" />
        </mxCell>

        <!-- ===== Network Firewall + ACM ===== -->
        <mxCell id="nfw_box" value="共有インフラ (アプリ非依存)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;fontStyle=1;align=left;verticalAlign=top;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="710" width="2120" height="200" as="geometry" />
        </mxCell>
        <mxCell id="nfw_d" value="Network Firewall&#xa;Suricata 互換ルール&#xa;Egress 集約検査&#xa;East-West 検査" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#232F3E;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.network_firewall;" vertex="1" parent="1">
          <mxGeometry x="200" y="760" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="acm_d" value="ACM Certs&#xa;(us-east-1)&#xa;auth.basis.example.com&#xa;admin.basis.example.com&#xa;app-a.example.com ..." style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#232F3E;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.certificate_manager;" vertex="1" parent="1">
          <mxGeometry x="400" y="760" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="cwl_waf" value="CloudWatch Logs&#xa;(全 WAF Logs)&#xa;→ Audit Acct S3" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#232F3E;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;" vertex="1" parent="1">
          <mxGeometry x="600" y="760" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- ===== Cross-Account 接続説明 ===== -->
        <mxCell id="xacct_box" value="Cross-Account 接続パターン (3 種)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0277bd;fontSize=11;fontStyle=1;align=left;verticalAlign=top;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="940" width="2120" height="190" as="geometry" />
        </mxCell>
        <mxCell id="xacct_text" value="① Public ALB + secret header&#xa;  CloudFront-Auth → Auth Acct Public ALB → Broker Keycloak&#xa;  (顧客 IdP からの SAML AuthnRequest 等で Public IPv4 必要)&#xa;  CloudFront から 'X-CloudFront-Secret' を付与、ALB Listener Rule で検証&#xa;&#xa;② VPC Origins (2024-12 GA) ★ 推奨&#xa;  CloudFront-AppA, B, C → App Acct Internal ALB (PrivateLink で直接接続)&#xa;  ALB 公開不要、AWS バックボーン経由、最も安全&#xa;&#xa;③ OAC (Origin Access Control)&#xa;  CloudFront → Auth Acct S3 (SPA bundles、サービス選択画面 / ユーザ管理画面 / エラー画面)&#xa;  S3 バケットポリシーで 'aws:SourceArn' を該当 CloudFront ARN に制限" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="160" y="970" width="2080" height="160" as="geometry" />
        </mxCell>

        <!-- ===== 凡例 ===== -->
        <mxCell id="legend_box" value="凡例 + 設計判断ポイント" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="1180" width="2200" height="380" as="geometry" />
        </mxCell>
        <mxCell id="legend_detail" value="◾ アプリごと独立 CloudFront/WAF/Lambda@Edge セット&#xa;  - 1 アプリ = 1 セット完全独立、Blast Radius 最小化&#xa;  - アプリ別 WAF ルールカスタマイズ可能 (カード扱いは厳格、社内ツールは緩い)&#xa;  - Lambda@Edge は CloudFront と同一 Acct 必須 (AWS 仕様) のためアプリごと独立&#xa;&#xa;◾ /admin パス保護 (重要)&#xa;  - WAF-Auth で /admin/* パスに対して全 IP Deny ルール (最優先)&#xa;  - Auth Platform Acct ALB Listener Rule で /admin/* は Internal Listener のみ受付&#xa;  - 弊社運用者は VPN/社内 NW → Transit Gateway → Auth Acct Internal ALB → Keycloak /admin の経路のみ&#xa;  - ユーザ管理画面 (admin.basis.example.com) は別物、外部からアクセス可 (テナントスコープ強制)&#xa;&#xa;◾ Shield Advanced (全社購入 $3K/月 × 1)&#xa;  - ネットワーク監査 Acct 内の全 CloudFront を透過的に保護&#xa;  - DDoS Response Team サポート含む&#xa;&#xa;◾ Network Firewall (Egress + East-West 検査)&#xa;  - Transit Gateway 経由の通信を検査&#xa;  - VPC → インターネットへの通信 (C&amp;C 通信 / DLP)&#xa;  - Auth Acct ↔ App Acct ↔ Network Acct 間の通信 (必要時)&#xa;&#xa;◾ コスト試算 (10 アプリ想定)&#xa;  - CloudFront 10 個: $500/月 + WAF Web ACL 10 個: $50/月 + WAF Managed Rules × 10: $3,100/月&#xa;  - Lambda@Edge 10 個: $200/月 + Network Firewall: $600/月 + Shield Advanced: $3,000/月&#xa;  - ACM: $0 / 合計 〜$7,560/月 (年 〜$91K)&#xa;  - v1 集約モデル比 +$3K/月 (アプリ間影響分離 + アプリ別 WAF カスタマイズのメリットを許容)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="120" y="1210" width="2160" height="340" as="geometry" />
        </mxCell>

        <!-- ===== セット内接続 ===== -->
