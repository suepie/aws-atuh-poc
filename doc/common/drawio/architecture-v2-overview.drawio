          <mxGeometry x="1040" y="1060" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="app_c_alb" value="App C&#xa;Internal ALB" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#232F3E;dashed=5;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.application_load_balancer;" vertex="1" parent="1">
          <mxGeometry x="1400" y="1060" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- ===== 🔵 監査 Acct ===== -->
        <mxCell id="audit_lane" value="🔵 監査 Acct  —  Compliance チーム  /  AWS Organizations + CloudTrail Org Trail + 監査ログ集約 S3 (Object Lock 7 年) + Security Hub + GuardDuty + OpenSearch" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="280" y="1290" width="2080" height="200" as="geometry" />
        </mxCell>
        <mxCell id="org" value="AWS Organizations&#xa;(全 Acct 統制)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#232F3E;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.organizations;" vertex="1" parent="1">
          <mxGeometry x="500" y="1360" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="cloudtrail" value="CloudTrail&#xa;Organization Trail" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#232F3E;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudtrail;" vertex="1" parent="1">
          <mxGeometry x="700" y="1360" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="audit_s3" value="監査ログ集約 S3&#xa;Object Lock 7 年" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#232F3E;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="900" y="1360" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="opensearch" value="OpenSearch&#xa;(ITDR / 監査検索)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#3334B9;strokeColor=#232F3E;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.opensearch_service;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1360" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="securityhub" value="Security Hub" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#232F3E;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.security_hub;" vertex="1" parent="1">
          <mxGeometry x="1300" y="1360" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="guardduty" value="GuardDuty" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#232F3E;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.guardduty;" vertex="1" parent="1">
          <mxGeometry x="1500" y="1360" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- ===== 凡例 ===== -->
        <mxCell id="legend" value="凡例" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="1510" width="2320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="legend_text" value="◾ 接続線:&#xa;  ━━━ HTTPS / Cross-Account（VPC Origins / OAC / Public ALB + secret header）&#xa;  ┄┄┄ VPN / 社内 NW (Internal アクセス、/admin 専用)&#xa;  ╳╳╳ /admin パス WAF Deny ルール (赤破線)&#xa;◾ 5 アカウント体系: 🔷 ネットワーク / 🟣 ネットワーク監査 / 🔵 監査 / 🟠 Auth Platform / 🟢 App (複数)&#xa;◾ アプリごと独立 CloudFront + WAF (1 アプリ = 1 CloudFront + 1 WAF + 1 Lambda@Edge セット、ネットワーク監査 Acct 内)&#xa;◾ Route 53 各 App Acct で別管理 (Hosted Zone はアプリチーム所有)&#xa;◾ /admin パス保護 = CloudFront WAF で外部 IP 全 Deny + VPN/社内 → Transit GW → Internal ALB のみ&#xa;◾ 認可 C ハイブリッド案: ユーザ管理画面で ON/OFF + 粗 roles 編集、詳細権限は各アプリ DB" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="1540" width="2280" height="140" as="geometry" />
        </mxCell>

        <!-- ===== 主要接続線 ===== -->
        <!-- エンドユーザー → Route 53 → CloudFront-Auth -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#2196f3;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="end_user" target="cf_auth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- エンドユーザー → CloudFront-AppA -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#2196f3;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="end_user" target="cf_appa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 顧客テナント管理者 → CloudFront-Admin -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;strokeColor=#2196f3;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="tenant_admin" target="cf_admin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 弊社運用者 → VPN → TGW → Internal ALB (Internal経路、破線) -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#f57c00;strokeWidth=2;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="op_user" target="vpn">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="520" />
              <mxPoint x="1380" y="520" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#f57c00;strokeWidth=2;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="vpn" target="tgw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#f57c00;strokeWidth=2;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="tgw" target="internal_alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 顧客IdP → Broker KC (SAML/OIDC) -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#9c27b0;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="customer_idp" target="broker_kc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 人事DB → SCIM Server (SCIM Push, ADR-054) -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#009688;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="hr_db" target="scim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- CloudFront-Auth → Public ALB (Cross-Acct, secret header) -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="cf_auth" target="public_alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- CloudFront-Auth → S3 SPA (OAC) -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="cf_auth" target="s3_spa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- CloudFront-AppA → App A Internal ALB (VPC Origins) -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" parent="1" source="cf_appa" target="app_a_alb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- CloudTrail → Audit S3 -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1565c0;strokeWidth=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="cloudtrail" target="audit_s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
