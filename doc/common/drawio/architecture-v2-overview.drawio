          <mxGeometry x="1020" y="1840" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="iam_ic" value="IAM Identity&#xa;Center&#xa;弊社運用者 SSO" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#232F3E;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=9;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management_identity;" vertex="1" parent="1">
          <mxGeometry x="1140" y="1840" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="audit_note" value="📝 監査メール対応 (ADR-036 Scope Reduced)&#xa;・Trust Center / Customer Portal は削除（スコープアウト）&#xa;・顧客監査要請は Compliance 担当が都度メール対応&#xa;・監査ログ保管 + NDA テンプレ準備のみ&#xa;📝 ADR-040 PAM Out of Scope&#xa;・KC ネイティブ /admin は WAF 全 IP Deny + Internal 経路のみ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=9;fontStyle=0;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1240" y="1830" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="game_day" value="📝 ADR-044 Tabletop Exercise&#xa;・3 種 × 4 頻度マトリクス&#xa;・経営/技術 Tabletop / Functional / Game Day&#xa;・Red Team (年 1) / 顧客通知シミュ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1640" y="1830" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="phase2_notes" value="📝 Phase 2 / 検討要素&#xa;・§C-7.3.18 Accessibility (WCAG 2.2 AA + JIS X 8341-3)&#xa;・§C-7.3.19 Tabletop Exercise (年間 14 回想定)&#xa;・§C-7.3.22 PQC マイグレーション (2026-2035)&#xa;・§C-7.3.24 Vendor Risk Management (TPRM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=9;align=left;verticalAlign=top;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1940" y="1830" width="480" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dr_note_audit" value="📝 ADR-051 Multi-Region DR&#xa;・Active-Passive Warm Standby&#xa;・プライマリ ap-northeast-1 / DR ap-northeast-3&#xa;・Aurora Global / DDB Global Tables / S3 CRR / KMS MRK&#xa;・Tier 1 (規制業種) RTO 30 分 / Tier 2 標準 RTO 1 時間 / RPO 1 分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="1950" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="mobile_note_audit" value="📝 §C-7.3.25 モバイル認証 (ADR-050)&#xa;・弊社業務アプリのエンドユーザ認証&#xa;・AppAuth + PKCE + System Browser&#xa;・WebAuthn Platform / Phase 2: Push MFA + App Attest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1950" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="rate_limit_note" value="📝 §C-7.3.27 認証 API への Rate Limit (ADR-052 縮小)&#xa;・WAF Rate Limit + API GW Usage Plan のみ (簡易)&#xa;・Pool/Silo モデル, Tier 別 Quota 等は API プラットフォーム側" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=9;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1700" y="1950" width="720" height="100" as="geometry" />
        </mxCell>

        <!-- ===== 凡例 ===== -->
        <mxCell id="legend_box" value="凡例 + 設計判断ポイント" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="2080" width="3320" height="280" as="geometry" />
        </mxCell>
        <mxCell id="legend_detail" value="◾ 5 アカウント体系 (ADR-039 v2): 🔷 ネットワーク / 🟣 ネットワーク監査 / 🔵 監査 / 🟠 Auth Platform / 🟢 App (複数)&#xa;◾ アプリごと独立 CloudFront + WAF + Lambda@Edge (ネットワーク監査 Acct 内)、Route 53 は各 App Acct で別管理&#xa;◾ /admin パス保護: KC ネイティブ /admin は WAF 全 IP Deny + Internal (VPN/社内 → Transit GW → Auth Acct Internal ALB) のみ&#xa;◾ ユーザ管理画面 (admin.basis.example.com) は別物、顧客テナント管理者が外部からアクセス可（テナントスコープ強制）&#xa;◾ 認可 C ハイブリッド (ADR-038): L1 アクセス可否 (apps[]) は本基盤、L2 アプリ内詳細権限はアプリ DB / JWT は {sub, tenant_id, apps[], roles{}} 最小化&#xa;◾ HRD Custom SPI (Java、ADR-055 Phase 1 確定、社内開発): 識別子先行 (ID/メアド両対応)、Keycloak User Attribute マッピング DB 参照 → kc_idp_hint AuthNote 設定 → Identity Provider Redirector 標準で IdP リダイレクト&#xa;◾ ID 統合 (ADR-054): 人事 DB SoT → SCIM Push → Keycloak User Attribute マッピング DB (5 Phase × 1.5 年移行、メアド不可は社員番号ベース)&#xa;◾ 認証コア: Broker KC + IdP-KC 2-tier (ADR-033), Single Realm + Organizations (ADR-017), 3 階層識別子 (ADR-018 sub/external_id/IdP sub), JWT 署名 ES256&#xa;◾ 鍵管理 3 階層 (ADR-045): L1 共通 MRK / L2 アカウント別 / L3 テナント別 (大規模顧客のみ), JWT 署名鍵 ES256, 鍵管理者 SoD&#xa;◾ Bot Detection (ADR-042): Phase 1 = WAF Bot Control + ATP のみ (PCI DSS §6.4.2 充足) / Phase 2 オプション = Cloudflare Turnstile&#xa;◾ Workload Identity (ADR-041): EKS Pod Identity + Keycloak FedID で client_secret 廃止 (PCI DSS §8.6.1/8.6.2 充足)&#xa;◾ Observability (ADR-053): OpenTelemetry + AMP + AMG + X-Ray, SLO + Error Budget Burn Rate Alert, ログ 3 階層 (Hot 3 ヶ月 / Warm 1 年 / Cold 6 年)&#xa;◾ DSAR Backend (ADR-048): Step Functions State Machine, 機械可読 5 形式 (JSON/SCIM/CSV/XLSX/OIDC UserInfo), GDPR 30 日 / APPI 遅滞なく&#xa;◾ Multi-Region DR (ADR-051): Active-Passive Warm Standby, Aurora Global + DDB Global Tables + S3 CRR + KMS MRK, Tier 1 RTO 30 分 / Tier 2 RTO 1 時間" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=none;strokeColor=none;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="2110" width="3280" height="250" as="geometry" />
        </mxCell>

