# Keycloak設定
# ローカル: http://localhost:8080/realms/auth-poc
# AWS:     http://<ALB DNS>/realms/auth-poc（terraform output keycloak_oidc_issuer）
VITE_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/auth-poc
VITE_KEYCLOAK_CLIENT_ID=auth-poc-spa
VITE_REDIRECT_URI=http://localhost:5174/callback
VITE_POST_LOGOUT_URI=http://localhost:5174/

# API Gateway エンドポイント（Lambda AuthorizerにKeycloak issuerを追加した場合）
VITE_API_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/prod
