    { "name": "lastName", "displayName": "${lastName}", "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] }, "multivalued": false },
    { "name": "provisioned_by", "displayName": "Provisioned By (jit/scim)", "permissions": { "view": ["admin"], "edit": ["admin"] }, "multivalued": false },
    { "name": "scim_active", "displayName": "SCIM Active", "permissions": { "view": ["admin"], "edit": ["admin"] }, "multivalued": false },
    { "name": "scim_external_id", "displayName": "SCIM External ID", "permissions": { "view": ["admin"], "edit": ["admin"] }, "multivalued": false },
    { "name": "last_login", "displayName": "Last Login (epoch ms)", "permissions": { "view": ["admin"], "edit": ["admin"] }, "multivalued": false },
    { "name": "jit_created_at", "displayName": "JIT Created At (epoch ms)", "permissions": { "view": ["admin"], "edit": ["admin"] }, "multivalued": false }
